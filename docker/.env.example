# ============================================
# WEATHER ETL PIPELINE - CONFIGURATION TEMPLATE
# ============================================
# Copy this file to docker/.env and fill in your actual values
# DO NOT commit docker/.env to git - it contains sensitive information!

# ============================================
# PYTHON & SYSTEM
# ============================================
PYTHONUNBUFFERED=1
COMPOSE_PROJECT_NAME=superset
DEV_MODE=true

# ============================================
# WEATHER API CONFIGURATION
# ============================================
# Get your API key from: https://weatherstack.com/
WEATHER_API_BASE_URL=http://api.weatherstack.com/current
WEATHER_API_KEY=your_api_key_here
WEATHER_API_CITY=New York

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Main PostgreSQL database
DATABASE_DB=superset
DATABASE_HOST=db
DATABASE_USER=superset
DATABASE_PASSWORD=change_me_to_secure_password
DATABASE_DIALECT=postgresql+psycopg2
DATABASE_PORT=5432

# Postgres container
POSTGRES_DB=superset_db
POSTGRES_USER=superset
POSTGRES_PASSWORD=change_me_to_secure_password

# Examples database
EXAMPLES_DB=examples_db
EXAMPLES_HOST=db
EXAMPLES_USER=examples
EXAMPLES_PASSWORD=change_me_to_secure_password
EXAMPLES_PORT=5432

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# PYTHON PATHS
# ============================================
PYTHONPATH=/app/pythonpath:/app/docker/pythonpath_dev

# ============================================
# SUPERSET CONFIGURATION
# ============================================
SUPERSET_ENV=development
SUPERSET_LOAD_EXAMPLES=no
SUPERSET_PORT=8088
SUPERSET_APP_ROOT=/
FLASK_DEBUG=true
SUPERSET_LOG_LEVEL=info

# CRITICAL: Change this in production!
SUPERSET_SECRET_KEY=change_me_in_production

# ============================================
# TESTING & ADVANCED
# ============================================
CYPRESS_CONFIG=false
ENABLE_PLAYWRIGHT=false
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
BUILD_SUPERSET_FRONTEND_IN_DOCKER=true
MAPBOX_API_KEY=
